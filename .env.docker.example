# Copy this file to .env.docker before running docker compose
# cp .env.docker.example .env.docker

# Docker-local environment for app + postgres in docker-compose
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# Auth
NEXTAUTH_URL=http://localhost:3004
AUTH_TRUST_HOST=true
AUTH_SECRET=change-this-to-a-strong-random-secret

# Prisma / Postgres (service name db from docker-compose)
DATABASE_URL=postgresql://botomoto:botomoto@db:5432/botomoto
DIRECT_URL=postgresql://botomoto:botomoto@db:5432/botomoto

# Queue
QUEUE_BACKEND=inmemory

# Email (dummy defaults for local container boot)
EMAIL_PROVIDERS=gmail
EMAIL_FROM_ADDRESS=botomoto@example.com
GMAIL_USER=botomoto@example.com
GMAIL_PASS=replace-with-app-password

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./uploads
LOCAL_BASE_URL=/api/files
LOCAL_PUBLIC_PATH=/uploads

# Optional app values
ELECTION_RESULTS_REFRESH_TYPE=polling
POLLING_SECONDS=5

SUPERADMIN_EMAIL=superadmin@botomoto.com               # Replace with your desired super admin email
SUPERADMIN_PASSWORD=Superadmin@123                      # Replace with your desired super admin password

