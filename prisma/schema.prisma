// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL_SQLITE")
}

// Enhanced User model for RBAC system
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  password      String?  // For credentials login
  role          UserRole        @default(VOTER) // Enhanced role system
  emailVerified DateTime?
  image         String?
  
  // Organization relationship for admins
  organization  Organization?
  
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Enhanced role enum
enum UserRole {
  VOTER
  ADMIN
  SUPER_ADMIN
}

// Organization approval status enum
enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// Election status enum
enum ElectionStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  ARCHIVED
}

// MFA method enum
enum MfaMethod {
  EMAIL
  TOTP
  SMS
}

// Voting scope type enum
enum VotingScopeType {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  CUSTOM
}

// Ticket status enum
enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// Audit action enum
enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  VOTE
  APPROVE
  REJECT
}
 
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}
 
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([userId, credentialID])
}

// Enhanced Organization model
model Organization {
  id            Int                  @id @default(autoincrement())
  adminId       String               @unique // Changed to String to match User.id
  name          String
  description   String
  membersCount  Int
  status        OrganizationStatus   @default(PENDING)
  photoUrl      String?
  letterUrl     String? // For approval documents
  frequency     String? // Election frequency
  theme         Json? // UI theme configuration
  
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  isDeleted     Boolean              @default(false)

  admin          User                @relation(fields: [adminId], references: [id])
  contactDetails OrgContactDetails[]
  elections      Election[]
  tickets        Ticket[]
}

model OrgContactDetails {
  id        Int          @id @default(autoincrement())
  orgId     Int
  name      String
  email     String
  contactNum String

  organization Organization @relation(fields: [orgId], references: [id])
}

model Election {
  id          Int            @id @default(autoincrement())
  orgId       Int
  name        String
  description String
  status      ElectionStatus @default(DRAFT)
  isLive      Boolean        @default(false) // For real-time voting
  allowSurvey Boolean        @default(false) // Enable post-vote survey
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean        @default(false)

  organization Organization @relation(fields: [orgId], references: [id])
  schedule     ElectionSched?
  mfaSettings  MfaSettings?
  votingScopes VotingScope[]
  voters       Voter[]
  positions    Position[]
  parties      Party[]
  candidates   Candidate[]
  voteResponses VoteResponse[]
  surveyForm   SurveyForm?
  broadcasts   Broadcast[]
}

model ElectionSched {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  dateStart   DateTime
  dateFinish  DateTime

  election Election @relation(fields: [electionId], references: [id])
}

model MfaSettings {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  mfaEnabled  Boolean   @default(false)
  mfaMethod   MfaMethod @default(EMAIL)
  totpSecret  String?   // For TOTP setup

  election Election @relation(fields: [electionId], references: [id])
}

model VotingScope {
  id          Int             @id @default(autoincrement())
  electionId  Int
  name        String
  type        VotingScopeType
  description String

  election   Election  @relation(fields: [electionId], references: [id])
  voters     Voter[]
  positions  Position[]
}

model Voter {
  id              Int       @id @default(autoincrement())
  electionId      Int
  code            String    @unique // Globally unique voter code
  email           String?
  contactNum      String?
  firstName       String
  middleName      String?
  lastName        String
  codeSendStatus  String    @default("PENDING")
  isVerified      Boolean   @default(false)
  votingScopeId   Int?
  address         String?
  isActive        Boolean   @default(true)
  hasVoted        Boolean   @default(false)
  votedAt         DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  isDeleted       Boolean   @default(false)

  election       Election    @relation(fields: [electionId], references: [id])
  votingScope    VotingScope? @relation(fields: [votingScopeId], references: [id])
  candidate      Candidate?
  voteResponses  VoteResponse[]
  surveyResponses SurveyResponse[]
}

model Position {
  id             Int          @id @default(autoincrement())
  electionId     Int
  name           String
  description    String
  voteLimit      Int          @default(1)
  numOfWinners   Int          @default(1)
  votingScopeId  Int?
  order          Int          @default(0) // For ballot ordering
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  isDeleted      Boolean      @default(false)

  election      Election      @relation(fields: [electionId], references: [id])
  votingScope   VotingScope?  @relation(fields: [votingScopeId], references: [id])
  candidates    Candidate[]
  voteResponses VoteResponse[]
}

model Candidate {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int       @unique
  positionId  Int
  isNew       Boolean   @default(false)
  partyId     Int?
  imageUrl    String?
  bio         String?   // Candidate biography
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election     Election   @relation(fields: [electionId], references: [id])
  voter        Voter      @relation(fields: [voterId], references: [id])
  position     Position   @relation(fields: [positionId], references: [id])
  party        Party?     @relation(fields: [partyId], references: [id])
  leaderships  CandidateLeadershipExperience[]
  workExps     CandidateWorkExperience[]
  educations   CandidateEducationLevel[]
  voteResponses VoteResponse[]
}

model Party {
  id          Int       @id @default(autoincrement())
  electionId  Int
  name        String
  color       String
  logoUrl     String?
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election   Election    @relation(fields: [electionId], references: [id])
  candidates Candidate[]
}

model CandidateLeadershipExperience {
  id            Int       @id @default(autoincrement())
  candidateId   Int
  organization  String
  position      String
  dateRange     String
  description   String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model CandidateWorkExperience {
  id          Int       @id @default(autoincrement())
  candidateId Int
  company     String
  role        String
  dateRange   String
  description String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model CandidateEducationLevel {
  id            Int       @id @default(autoincrement())
  candidateId   Int
  school        String
  educationLevel String
  dateRange     String
  description   String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model VoteResponse {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int
  candidateId Int
  positionId  Int
  voteHash    String    // For vote integrity
  timestamp   DateTime  @default(now())

  election   Election   @relation(fields: [electionId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
  candidate  Candidate  @relation(fields: [candidateId], references: [id])
  position   Position   @relation(fields: [positionId], references: [id])
}

model SurveyForm {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  title       String
  description String
  formSchema  Json
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election        Election         @relation(fields: [electionId], references: [id])
  surveyResponses SurveyResponse[]
}

model SurveyResponse {
  id         Int       @id @default(autoincrement())
  formId     Int
  voterId    Int
  answers    Json
  submittedAt DateTime @default(now())

  surveyForm SurveyForm @relation(fields: [formId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
}

model Ticket {
  id        Int         @id @default(autoincrement())
  orgId     Int
  subject   String
  message   String
  status    TicketStatus @default(OPEN)
  priority  String      @default("MEDIUM")
  response  String?     // SuperAdmin response
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  closedAt  DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
}

model Broadcast {
  id          Int       @id @default(autoincrement())
  electionId  Int
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  isSent      Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  election Election @relation(fields: [electionId], references: [id])
}

model Audits {
  id         Int        @id @default(autoincrement())
  actorId    String     // User ID who performed the action
  actorRole  UserRole   // Role of the actor
  action     AuditAction
  ipAddress  String
  userAgent  String
  resource   String?    // What resource was affected
  resourceId String?    // ID of the affected resource
  details    Json?      // Additional details
  
  timestamp  DateTime   @default(now())

  affectedTables AuditTableAffected[]
}

model AuditTableAffected {
  id            Int     @id @default(autoincrement())
  auditId       Int
  tableAffected String
  recordId      String
  changes       Json

  audit Audits @relation(fields: [auditId], references: [id])
}