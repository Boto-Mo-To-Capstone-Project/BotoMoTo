```

### 8. Voter Model
```prisma
model Voter {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  email       String?
  phone       String?
  votingScopeId String
  votingScope VotingScope @relation(fields: [votingScopeId], references: [id])
  electionId  String
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  hasVoted    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One-to-one relationship with Admin User
  admin       User @relation(fields: [adminId], references: [id])
  // Relations
  votes       Vote[]
  surveys     Survey[]

  @@index([code])
  @@index([electionId])
  @@index([votingScopeId])
  @@unique([email, electionId])
}
```

### 9. Vote Model
```prisma
model Vote {
  id          String   @id @default(cuid())
  voterId     String
  voter       Voter @relation(fields: [voterId], references: [id], onDelete: Cascade)
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  electionId  String
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  votingScopeId String
  votingScope VotingScope @relation(fields: [votingScopeId], references: [id])
  hash        String   @unique
  previousHash String?
  createdAt   DateTime @default(now())

  @@index([voterId])
  @@index([candidateId])
  @@index([electionId])
  @@index([votingScopeId])
  @@unique([voterId, candidateId])
}
```

### 10. Survey Model
```prisma
model Survey {
  id          String   @id @default(cuid())
  voterId     String
  voter       Voter @relation(fields: [voterId], references: [id], onDelete: Cascade)
  electionId  String
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  responses   Json
  createdAt   DateTime @default(now())

  @@index([voterId])
  @@index([electionId])
  @@unique([voterId, electionId])
}
```

### 11. Session Model
```prisma
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime
  createdAt    DateTime @default(now())

  @@index([sessionToken])
  @@index([userId])
}
```

### 12. Ticket Model
```prisma
model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  status      TicketStatus @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  userId      String
  user        User @relation(fields: [userId], references: [id])
  // One-to-one relationship with Organization
  organization Organization? @relation(fields: [organizationId], references: [id])
  electionId  String?
  election    Election? @relation(fields: [electionId], references: [id])
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // One-to-one relationship with Admin User
  admin       User @relation(fields: [adminId], references: [id])
  // Relations
  messages    TicketMessage[]

  @@index([userId])
  // One-to-one relationship indexed by adminId
  @@index([electionId])
  @@index([status])
}
```

### 13. TicketMessage Model
```prisma
model TicketMessage {
  id        String   @id @default(cuid())
  content   String
  ticketId  String
  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([userId])
}
```

### 14. Audit Model
```prisma
model Audit {
  id          String   @id @default(cuid())
  action      String
  entityType  String
  entityId    String
  userId      String
  user        User @relation(fields: [userId], references: [id])
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}
```

