// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enhanced User model for RBAC system
model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  password      String?  // For credentials login
  role          UserRole        @default(ADMIN) // Enhanced role system
  emailVerified DateTime?
  image         String?
  
  // Organization relationship for admins
  organization  Organization?
  
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
  userSessions  UserSession[] // For performance tracking
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Enhanced role enum
enum UserRole {
  VOTER
  ADMIN
  SUPER_ADMIN
}

enum AuditResource {
  ORGANIZATION
  USER
  ELECTION
  CANDIDATE
  PARTY
  VOTING_SCOPE
  VOTER
  POSITION
  TICKET
  // Add other resources as needed
}

// Organization approval status enum
enum OrganizationStatus {
  PENDING
  APPROVED
  REJECTED
}

// Election status enum
enum ElectionStatus {
  DRAFT
  ACTIVE
  CLOSED
}

// MFA method enum
enum MfaMethod {
  EMAIL
  TOTP
  SMS
}

// Ticket status enum
enum TicketStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
}

// Audit action enum
enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  RESTORE
  SIGNUP
  LOGIN
  LOGOUT
  VOTE
  APPROVE
  REJECT
  UPLOAD
}

// Code send status enum
enum CodeSendStatus {
  PENDING
  SENDING
  SENT
  FAILED
}
 
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@unique([provider, providerAccountId])
}
 
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
 
model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}
 
model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
 
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
 
  @@id([userId, credentialID])
}

// Enhanced Organization model
model Organization {
  id            Int                  @id @default(autoincrement())
  adminId       String               @unique // Changed to String to match User.id
  name          String
  email         String               // <--- Added email field
  membersCount  Int
  status        OrganizationStatus   @default(PENDING)
  photoUrl      String?
  letterUrl     String? 

  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?
  isDeleted     Boolean              @default(false)

  admin          User                @relation(fields: [adminId], references: [id])
  // contactDetails OrgContactDetails[]
  elections      Election[]
  tickets        Ticket[]
  emailLogs      EmailLog[]
  emailSuppressions EmailSuppression[]
  emailTemplates EmailTemplate[]
}

model Election {
  id          Int            @id @default(autoincrement())
  orgId       Int
  name        String
  description String
  status      ElectionStatus @default(DRAFT)
  isLive      Boolean        @default(false) // For real-time voting
  allowSurvey Boolean        @default(false) // Enable post-vote survey
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean        @default(false)

  organization Organization @relation(fields: [orgId], references: [id])
  schedule     ElectionSched?
  mfaSettings  MfaSettings?
  votingScopes VotingScope[]
  voters       Voter[]
  positions    Position[]
  parties      Party[]
  candidates   Candidate[]
  voteResponses VoteResponse[]
  broadcasts   Broadcast[]
  emailLogs    EmailLog[]
}

model ElectionSched {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  dateStart   DateTime
  dateFinish  DateTime

  election Election @relation(fields: [electionId], references: [id])
}

model MfaSettings {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  mfaEnabled  Boolean   @default(false)
  mfaMethod   MfaMethod @default(EMAIL)
  totpSecret  String?   // For TOTP setup

  election Election @relation(fields: [electionId], references: [id])
}

model VotingScope {
  id          Int             @id @default(autoincrement())
  electionId  Int
  name        String
  description String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election   Election  @relation(fields: [electionId], references: [id])
  voters     Voter[]
  positions  Position[]
}

model Voter {
  id              Int       @id @default(autoincrement())
  electionId      Int
  code            String    @unique // Globally unique voter code (also serves as voting code)
  email           String?
  contactNum      String?
  firstName       String
  middleName      String?
  lastName        String
  codeSendStatus  CodeSendStatus @default(PENDING)
  isVerified      Boolean   @default(false)
  votingScopeId   Int?
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  isDeleted       Boolean   @default(false)

  election       Election    @relation(fields: [electionId], references: [id])
  votingScope    VotingScope? @relation(fields: [votingScopeId], references: [id])
  candidate      Candidate?
  voteResponses  VoteResponse[]
  surveyResponses SurveyResponse[]
}

model Position {
  id             Int          @id @default(autoincrement())
  electionId     Int
  name           String
  voteLimit      Int          @default(1)
  numOfWinners   Int          @default(1)
  votingScopeId  Int?
  order          Int          @default(0) // For ballot ordering
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  isDeleted      Boolean      @default(false)

  election      Election      @relation(fields: [electionId], references: [id])
  votingScope   VotingScope?  @relation(fields: [votingScopeId], references: [id])
  candidates    Candidate[]
  voteResponses VoteResponse[]
}

model Candidate {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int       @unique
  positionId  Int
  isNew       Boolean   @default(false)
  partyId     Int?
  imageUrl    String?
  credentialUrl String? // path to credentials file
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election     Election   @relation(fields: [electionId], references: [id])
  voter        Voter      @relation(fields: [voterId], references: [id])
  position     Position   @relation(fields: [positionId], references: [id])
  party        Party?     @relation(fields: [partyId], references: [id])
  voteResponses VoteResponse[]
}

model Party {
  id          Int       @id @default(autoincrement())
  electionId  Int
  name        String
  color       String
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election   Election    @relation(fields: [electionId], references: [id])
  candidates Candidate[]

  @@unique([electionId, name])
}


model VoteResponse {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int
  candidateId Int
  positionId  Int
  voteHash    String    // For vote integrity
  timestamp   DateTime  @default(now())

  election   Election   @relation(fields: [electionId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
  candidate  Candidate  @relation(fields: [candidateId], references: [id])
  position   Position   @relation(fields: [positionId], references: [id])

  @@index([electionId, voterId])
  @@index([electionId, timestamp])
}

model SurveyForm {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  formSchema  Json
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  surveyResponses SurveyResponse[]
}

model SurveyResponse {
  id         Int       @id @default(autoincrement())
  formId     Int
  voterId    Int
  answers    Json
  submittedAt DateTime @default(now())

  surveyForm SurveyForm @relation(fields: [formId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
}

model Ticket {
  id          Int           @id @default(autoincrement())
  orgId       Int
  subject     String        // Ticket title/subject serves as the description
  status      TicketStatus  @default(PENDING)
  messages    Json        // Array to store chat messages: [{senderId, content, timestamp}]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  closedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
}

model Broadcast {
  id          Int       @id @default(autoincrement())
  electionId  Int
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  isSent      Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  election Election @relation(fields: [electionId], references: [id])
}

model Audits {
  id         Int        @id @default(autoincrement())
  actorId    String     // User ID who performed the action
  actorRole  UserRole   // Role of the actor
  action     AuditAction
  ipAddress  String
  userAgent  String
  resource   String?    // What resource was affected
  resourceId String?    // ID of the affected resource
  details    Json?      // Additional details  // should edit this if i switch to postgres
  
  timestamp  DateTime   @default(now())

  affectedTables AuditTableAffected[]
}

model AuditTableAffected {
  id            Int     @id @default(autoincrement())
  auditId       Int
  tableAffected String
  recordId      String
  changes       Json

  audit Audits @relation(fields: [auditId], references: [id])
}

// Performance Logging Tables for Analytics Dashboard
model ApiLog {
  id           String   @id @default(cuid())
  endpoint     String   // The API endpoint called (e.g., "/api/organizations")
  method       String   // HTTP method (GET, POST, PUT, DELETE)
  statusCode   Int      // HTTP status code (200, 404, 500, etc.)
  responseTime Int      // Response time in milliseconds
  userId       String?  // ID of user who made the request (if authenticated)
  ipAddress    String   // Client IP address
  userAgent    String?  // Browser/client user agent
  error        String?  // Error message if request failed
  
  createdAt    DateTime @default(now())
  
  // Index for fast queries on recent data and performance analysis
  @@index([createdAt])
  @@index([endpoint, createdAt])
  @@index([statusCode, createdAt])
  @@map("api_logs")
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String    // User who started the session
  startedAt DateTime  @default(now())
  endedAt   DateTime? // When session ended (null = still active)
  ipAddress String    // Session IP address
  userAgent String?   // Browser/device info
  
  // Relation to user for data consistency
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Indexes for concurrent user calculations
  @@index([startedAt, endedAt])
  @@index([userId, startedAt])
  @@map("user_sessions")
}

model SystemMetric {
  id         String   @id @default(cuid())
  metricType String   // Type: 'uptime', 'memory_usage', 'cpu_usage', 'disk_space'
  value      Float    // Metric value (e.g., 99.5 for 99.5% uptime)
  metadata   Json?    // Additional metric data (optional)
  recordedAt DateTime @default(now())
  
  // Index for time-series queries
  @@index([metricType, recordedAt])
  @@map("system_metrics")
}

// Email System Models

model EmailTemplate {
  id             String    @id @default(cuid())
  
  // Template details
  name           String    // User-friendly name
  description    String?   // Optional description
  templateId     String    // Unique identifier for template engine
  type           TemplateType @default(CUSTOM)
  
  // Content
  htmlContent    String    @db.Text // HTML template content
  textContent    String?   @db.Text // Optional text version
  defaultSubject String?   // Default subject line
  
  // File storage (for uploaded templates)
  fileName       String?   // Original filename
  fileSize       Int?      // File size in bytes
  filePath       String?   // Storage path
  
  // Organization isolation
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Audit fields
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      Int?      // User who created the template
  
  // Ensure unique template IDs per organization
  @@unique([organizationId, templateId])
  @@index([organizationId, type])
  @@index([templateId])
  @@map("email_templates")
}

enum TemplateType {
  SYSTEM        // Built-in system templates
  CUSTOM        // User-uploaded custom templates
}

model EmailLog {
  id            String        @id @default(cuid())
  
  // Message details
  messageId     String?       // Provider-specific message ID
  templateId    String?       // Template used (if any)
  
  // Recipients
  toEmail       String        // Primary recipient email
  toName        String?       // Primary recipient name
  ccEmails      String[]      // CC emails (array)
  bccEmails     String[]      // BCC emails (array)
  
  // Content
  subject       String
  htmlSize      Int?          // Size of HTML content in bytes
  textSize      Int?          // Size of text content in bytes
  attachments   Int?          @default(0) // Number of attachments
  
  // Sending details
  provider      String        // Email provider used (resend, ses, gmail-smtp)
  status        EmailStatus   @default(PENDING)
  
  // Timing
  queuedAt      DateTime      @default(now())
  sentAt        DateTime?     // When successfully sent
  deliveredAt   DateTime?     // When delivered (from webhook)
  openedAt      DateTime?     // When first opened (from webhook)
  clickedAt     DateTime?     // When first clicked (from webhook)
  
  // Error tracking
  error         String?       // Error message if failed
  retryCount    Int           @default(0)
  lastRetryAt   DateTime?
  
  // Metadata
  tags          Json?         // Custom tags for tracking
  campaign      String?       // Campaign identifier
  
  // Relations
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  electionId     Int?
  election       Election?     @relation(fields: [electionId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Indexes for performance
  @@index([toEmail, createdAt])
  @@index([provider, status, createdAt])
  @@index([templateId, createdAt])
  @@index([organizationId, createdAt])
  @@index([electionId, createdAt])
  @@index([status, queuedAt])
  @@map("email_logs")
}

model EmailSuppression {
  id            String              @id @default(cuid())
  email         String              @unique // Suppressed email address
  reason        SuppressionReason   
  source        String?             // Where the suppression came from
  
  // Timing
  suppressedAt  DateTime            @default(now())
  expiresAt     DateTime?           // When suppression expires (null = permanent)
  
  // Metadata
  bounceType    String?             // Hard bounce, soft bounce, etc.
  complaintType String?             // Spam complaint type
  metadata      Json?               // Additional provider-specific data
  
  // Relations
  organizationId Int?
  organization   Organization?       @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  
  // Indexes
  @@index([email])
  @@index([reason, suppressedAt])
  @@index([organizationId, email])
  @@index([expiresAt])
  @@map("email_suppressions")
}

// Email-related enums

enum EmailStatus {
  PENDING       // Queued for sending
  SENDING       // Currently being sent
  SENT          // Successfully sent to provider
  DELIVERED     // Delivered to recipient
  OPENED        // Email was opened
  CLICKED       // Email was clicked
  BOUNCED       // Bounced back
  COMPLAINED    // Marked as spam
  FAILED        // Failed to send
  SUPPRESSED    // Blocked due to suppression
}

enum SuppressionReason {
  BOUNCE        // Email bounced
  COMPLAINT     // Spam complaint
  UNSUBSCRIBE   // User unsubscribed
  MANUAL        // Manually added
  INVALID       // Invalid email address
  BLOCKED       // Blocked by provider
}