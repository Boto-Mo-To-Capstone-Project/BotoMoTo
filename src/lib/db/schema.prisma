model Election {
  id          Int            @id @default(autoincrement())
  orgId       Int
  name        String
  description String
  status      ElectionStatus @default(DRAFT)
  isLive      Boolean        @default(false) // For real-time voting
  allowSurvey Boolean        @default(false) // Enable post-vote survey

  // NEW: Optional election-level scope configuration
  scopeType      VotingScopeType?
  scopeTypeLabel String?
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean        @default(false)

  organization Organization @relation(fields: [orgId], references: [id])
  schedule     ElectionSched?
  mfaSettings  MfaSettings?
  votingScopes VotingScope[]
  voters       Voter[]
  positions    Position[]
  parties      Party[]
  candidates   Candidate[]
  voteResponses VoteResponse[]
  broadcasts   Broadcast[]
}

model ElectionSched {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  dateStart   DateTime
  dateFinish  DateTime

  election Election @relation(fields: [electionId], references: [id])
}

model MfaSettings {
  id          Int       @id @default(autoincrement())
  electionId  Int       @unique
  mfaEnabled  Boolean   @default(false)
  mfaMethod   MfaMethod @default(EMAIL)
  totpSecret  String?   // For TOTP setup

  election Election @relation(fields: [electionId], references: [id])
}

model VotingScope {
  id          Int             @id @default(autoincrement())
  electionId  Int
  name        String
  description String

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election   Election  @relation(fields: [electionId], references: [id])
  voters     Voter[]
  positions  Position[]
}

model Voter {
  id              Int       @id @default(autoincrement())
  electionId      Int
  code            String    @unique // Globally unique voter code
  email           String?
  contactNum      String?
  firstName       String
  middleName      String?
  lastName        String
  codeSendStatus  String    @default("PENDING")
  isVerified      Boolean   @default(false)
  votingScopeId   Int?
  address         String?
  isActive        Boolean   @default(true)
  hasVoted        Boolean   @default(false)
  votedAt         DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  isDeleted       Boolean   @default(false)

  election       Election    @relation(fields: [electionId], references: [id])
  votingScope    VotingScope? @relation(fields: [votingScopeId], references: [id])
  candidate      Candidate?
  voteResponses  VoteResponse[]
  surveyResponses SurveyResponse[]
}

model Position {
  id             Int          @id @default(autoincrement())
  electionId     Int
  name           String
  description    String
  voteLimit      Int          @default(1)
  numOfWinners   Int          @default(1)
  votingScopeId  Int?
  order          Int          @default(0) // For ballot ordering
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  isDeleted      Boolean      @default(false)

  election      Election      @relation(fields: [electionId], references: [id])
  votingScope   VotingScope?  @relation(fields: [votingScopeId], references: [id])
  candidates    Candidate[]
  voteResponses VoteResponse[]
}

model Candidate {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int       @unique
  positionId  Int
  isNew       Boolean   @default(false)
  partyId     Int?
  imageUrl    String?
  bio         String?   // Candidate biography
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election     Election   @relation(fields: [electionId], references: [id])
  voter        Voter      @relation(fields: [voterId], references: [id])
  position     Position   @relation(fields: [positionId], references: [id])
  party        Party?     @relation(fields: [partyId], references: [id])
  leaderships  CandidateLeadershipExperience[]
  workExps     CandidateWorkExperience[]
  educations   CandidateEducationLevel[]
  voteResponses VoteResponse[]
}

model Party {
  id          Int       @id @default(autoincrement())
  electionId  Int
  name        String
  color       String
  logoUrl     String?
  description String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  election   Election    @relation(fields: [electionId], references: [id])
  candidates Candidate[]

  @@unique([electionId, name])
}

model CandidateLeadershipExperience {
  id            Int       @id @default(autoincrement())
  candidateId   Int
  organization  String
  position      String
  dateRange     String
  description   String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model CandidateWorkExperience {
  id          Int       @id @default(autoincrement())
  candidateId Int
  company     String
  role        String
  dateRange   String
  description String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model CandidateEducationLevel {
  id            Int       @id @default(autoincrement())
  candidateId   Int
  school        String
  educationLevel String
  dateRange     String
  description   String?

  candidate Candidate @relation(fields: [candidateId], references: [id])
}

model VoteResponse {
  id          Int       @id @default(autoincrement())
  electionId  Int
  voterId     Int
  candidateId Int
  positionId  Int
  voteHash    String    // For vote integrity
  timestamp   DateTime  @default(now())

  election   Election   @relation(fields: [electionId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
  candidate  Candidate  @relation(fields: [candidateId], references: [id])
  position   Position   @relation(fields: [positionId], references: [id])
}

model SurveyForm {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  formSchema  Json
  isActive    Boolean   @default(true)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  isDeleted   Boolean   @default(false)

  surveyResponses SurveyResponse[]
}

model SurveyResponse {
  id         Int       @id @default(autoincrement())
  formId     Int
  voterId    Int
  answers    Json
  submittedAt DateTime @default(now())

  surveyForm SurveyForm @relation(fields: [formId], references: [id])
  voter      Voter      @relation(fields: [voterId], references: [id])
}

model Ticket {
  id          Int           @id @default(autoincrement())
  orgId       Int
  subject     String        // Ticket title/subject serves as the description
  status      TicketStatus  @default(PENDING)
  messages    Json        // Array to store chat messages: [{senderId, content, timestamp}]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  closedAt    DateTime?

  organization Organization @relation(fields: [orgId], references: [id])
}

model Broadcast {
  id          Int       @id @default(autoincrement())
  electionId  Int
  title       String
  message     String
  scheduledAt DateTime
  sentAt      DateTime?
  isSent      Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @default(now())

  election Election @relation(fields: [electionId], references: [id])
}

model Audits {
  id         Int        @id @default(autoincrement())
  actorId    String     // User ID who performed the action
  actorRole  UserRole   // Role of the actor
  action     AuditAction
  ipAddress  String
  userAgent  String
  resource   String?    // What resource was affected
  resourceId String?    // ID of the affected resource
  details    Json?      // Additional details  // should edit this if i switch to postgres
  
  timestamp  DateTime   @default(now())

  affectedTables AuditTableAffected[]
}

model AuditTableAffected {
  id            Int     @id @default(autoincrement())
  auditId       Int
  tableAffected String
  recordId      String
  changes       Json

  audit Audits @relation(fields: [auditId], references: [id])
}

// Performance Logging Tables for Analytics Dashboard
model ApiLog {
  id           String   @id @default(cuid())
  endpoint     String   // The API endpoint called (e.g., "/api/organizations")
  method       String   // HTTP method (GET, POST, PUT, DELETE)
  statusCode   Int      // HTTP status code (200, 404, 500, etc.)
  responseTime Int      // Response time in milliseconds
  userId       String?  // ID of user who made the request (if authenticated)
  ipAddress    String   // Client IP address
  userAgent    String?  // Browser/client user agent
  error        String?  // Error message if request failed
  
  createdAt    DateTime @default(now())
  
  // Index for fast queries on recent data and performance analysis
  @@index([createdAt])
  @@index([endpoint, createdAt])
  @@index([statusCode, createdAt])
  @@map("api_logs")
}

model UserSession {
  id        String    @id @default(cuid())
  userId    String    // User who started the session
  startedAt DateTime  @default(now())
  endedAt   DateTime? // When session ended (null = still active)
  ipAddress String    // Session IP address
  userAgent String?   // Browser/device info
  
  // Relation to user for data consistency
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Indexes for concurrent user calculations
  @@index([startedAt, endedAt])
  @@index([userId, startedAt])
  @@map("user_sessions")
}

model SystemMetric {
  id         String   @id @default(cuid())
  metricType String   // Type: 'uptime', 'memory_usage', 'cpu_usage', 'disk_space'
  value      Float    // Metric value (e.g., 99.5 for 99.5% uptime)
  metadata   Json?    // Additional metric data (optional)
  recordedAt DateTime @default(now())
  
  // Index for time-series queries
  @@index([metricType, recordedAt])
  @@map("system_metrics")
}